generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Result {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @default("")
  picture    String   @default("")
  quizId     String
  quizTitle  String   @default("Квіз")
  score      Int
  total      Int
  percentage Int
  mode       String   @default("exam")
  timeSpent  Int?
  answers    Json?
  date       DateTime @default(now())
}
